# Copy to .env and fill in values
# All variables are prefixed with REMEMBRA_

# Server
REMEMBRA_HOST=0.0.0.0
REMEMBRA_PORT=8787
REMEMBRA_DEBUG=false
REMEMBRA_LOG_LEVEL=info

# Qdrant
REMEMBRA_QDRANT_URL=http://localhost:6333
# REMEMBRA_QDRANT_API_KEY=

# Database (SQLite for dev, PostgreSQL for prod)
REMEMBRA_DATABASE_URL=sqlite+aiosqlite:///remembra.db

# Embeddings
REMEMBRA_EMBEDDING_PROVIDER=openai
REMEMBRA_EMBEDDING_MODEL=text-embedding-3-small
REMEMBRA_OPENAI_API_KEY=sk-xxx

# LLM (for extraction)
REMEMBRA_LLM_PROVIDER=openai
REMEMBRA_LLM_MODEL=gpt-4o-mini

# Features
REMEMBRA_ENABLE_ENTITY_RESOLUTION=true
REMEMBRA_ENABLE_TEMPORAL_DECAY=true
