# =============================================================================
# Remembra Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment
#
# Required: None (all have defaults)
# Recommended: Set OPENAI_API_KEY for better fact extraction
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
REMEMBRA_PORT=8787
REMEMBRA_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
# Require API key for all requests (recommended for production)
REMEMBRA_REQUIRE_API_KEY=true

# CORS origins (comma-separated, or * for all)
REMEMBRA_CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
REMEMBRA_RATE_LIMIT_STORE=30/minute
REMEMBRA_RATE_LIMIT_RECALL=60/minute

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
# Local model (default, no API key needed):
REMEMBRA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Or use OpenAI embeddings (requires OPENAI_API_KEY):
# REMEMBRA_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# LLM for Fact Extraction (Optional)
# -----------------------------------------------------------------------------
# Without LLM: Basic sentence splitting
# With LLM: Intelligent fact extraction, consolidation, entity recognition

# OpenAI
# REMEMBRA_LLM_PROVIDER=openai
# REMEMBRA_LLM_MODEL=gpt-4o-mini

# Anthropic
# REMEMBRA_LLM_PROVIDER=anthropic
# REMEMBRA_LLM_MODEL=claude-3-haiku-20240307

# Local (Ollama)
# REMEMBRA_LLM_PROVIDER=ollama
# REMEMBRA_LLM_MODEL=llama3.2

# -----------------------------------------------------------------------------
# API Keys (for LLM/Embedding providers)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Memory Defaults
# -----------------------------------------------------------------------------
# Default TTL for memories (leave empty for no expiration)
# Examples: 30 (30 days), 365 (1 year)
REMEMBRA_DEFAULT_TTL_DAYS=

# -----------------------------------------------------------------------------
# Qdrant Configuration
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# =============================================================================
# Advanced Configuration (rarely needed)
# =============================================================================

# Custom Qdrant URL (if not using docker-compose)
# REMEMBRA_QDRANT_URL=http://localhost:6333

# Qdrant collection name
# REMEMBRA_QDRANT_COLLECTION=memories

# Database URL (SQLite by default)
# REMEMBRA_DATABASE_URL=sqlite:////data/remembra.db
