{
  "name": "remembra",
  "version": "0.8.2",
  "description": "TypeScript/JavaScript SDK for Remembra - AI Memory Layer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "remembra",
    "ai",
    "memory",
    "llm",
    "agent",
    "rag",
    "vector",
    "embedding"
  ],
  "author": "DolphyTech <admin@dolphytech.com>",
  "license": "MIT",
  "homepage": "https://remembra.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/remembra-ai/remembra.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/remembra-ai/remembra/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
